generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  logoUrl     String?
  description String?
  address     String?
  website     String?
  status      CompanyStatus @default(ACTIVE)
  domain      String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  invitations Invitation[]
  teams       Team[]
  users       User[]

  @@index([status])
  @@index([deletedAt])
  @@map("companies")
}

model User {
  id                    String                  @id @default(uuid()) @db.Uuid
  email                 String                  @unique
  passwordHash          String?
  name                  String
  phone                 String?
  avatarUrl             String?
  role                  UserRole                @default(STUDENT)
  status                UserStatus              @default(PENDING_SETUP)
  companyId             String?                 @db.Uuid
  teamId                String?                 @db.Uuid
  mentorId              String?                 @db.Uuid
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  attendances           Attendance[]
  actorAuditLogs        AuditLog[]              @relation("ActorAuditLogs")
  sentInvitations       Invitation[]            @relation("SentInvitations")
  approvedLeaveRequests LeaveRequest[]          @relation("ApproverLeaveRequests")
  leaveRequests         LeaveRequest[]          @relation("StudentLeaveRequests")
  notifications         Notification[]
  passwordResetTokens   PasswordResetToken[]
  refreshTokens         RefreshToken[]
  moduleProgress        StudentModuleProgress[]
  ticketReplies         SupportTicketReply[]    @relation("TicketReplies")
  assignedTickets       SupportTicket[]         @relation("AssignedTickets")
  authoredTickets       SupportTicket[]         @relation("AuthoredTickets")
  createdTrainingPlans  TrainingPlan[]          @relation("CreatorTrainingPlans")
  company               Company?                @relation(fields: [companyId], references: [id])
  mentor                User?                   @relation("MentorStudents", fields: [mentorId], references: [id])
  students              User[]                  @relation("MentorStudents")
  team                  Team?                   @relation(fields: [teamId], references: [id])

  @@index([companyId])
  @@index([teamId])
  @@index([mentorId])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  email       String
  role        UserRole
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  companyId   String           @db.Uuid
  teamId      String?          @db.Uuid
  invitedById String           @db.Uuid
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  team        Team?            @relation(fields: [teamId], references: [id])

  @@index([email])
  @@index([companyId])
  @@index([teamId])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Attendance {
  id               String           @id @default(uuid()) @db.Uuid
  date             DateTime         @db.Date
  checkIn          DateTime?
  checkOut         DateTime?
  checkInIp        String?
  checkOutIp       String?
  checkInLocation  String?
  checkOutLocation String?
  status           AttendanceStatus @default(ABSENT)
  note             String?
  userId           String           @db.Uuid
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([status])
  @@index([userId, date])
  @@index([deletedAt])
  @@map("attendances")
}

model Team {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  companyId     String         @db.Uuid
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  invitations   Invitation[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trainingPlans TrainingPlan[]
  users         User[]

  @@index([companyId])
  @@index([deletedAt])
  @@map("teams")
}

model TrainingPlan {
  id          String               @id @default(uuid()) @db.Uuid
  title       String
  description String?
  teamId      String               @db.Uuid
  createdById String               @db.Uuid
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  modules     TrainingPlanModule[]
  createdBy   User                 @relation("CreatorTrainingPlans", fields: [createdById], references: [id], onDelete: Cascade)
  team        Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([deletedAt])
  @@map("training_plans")
}

model TrainingPlanModule {
  id             String                  @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  weekNumber     Int
  fileUrl        String?
  externalLink   String?
  dueDate        DateTime?
  trainingPlanId String                  @db.Uuid
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  progresses     StudentModuleProgress[]
  trainingPlan   TrainingPlan            @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@index([trainingPlanId])
  @@index([deletedAt])
  @@map("training_plan_modules")
}

model StudentModuleProgress {
  id          String             @id @default(uuid()) @db.Uuid
  studentId   String             @db.Uuid
  moduleId    String             @db.Uuid
  status      TrainingPlanStatus @default(ACTIVE)
  completedAt DateTime?
  module      TrainingPlanModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  student     User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
  @@index([studentId])
  @@index([moduleId])
  @@map("student_module_progress")
}

model LeaveRequest {
  id            String      @id @default(uuid()) @db.Uuid
  type          LeaveType
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  reason        String
  attachmentUrl String?
  status        LeaveStatus @default(PENDING)
  approverNote  String?
  submittedAt   DateTime    @default(now())
  reviewedAt    DateTime?
  studentId     String      @db.Uuid
  approvedById  String?     @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  approvedBy    User?       @relation("ApproverLeaveRequests", fields: [approvedById], references: [id])
  student       User        @relation("StudentLeaveRequests", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([approvedById])
  @@index([deletedAt])
  @@map("leave_requests")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  userId    String           @db.Uuid
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  action     AuditAction
  entityName String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  actorId    String?     @db.Uuid
  createdAt  DateTime    @default(now())
  actor      User?       @relation("ActorAuditLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityName, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SupportTicket {
  id           String                @id @default(uuid()) @db.Uuid
  subject      String
  description  String
  status       SupportTicketStatus   @default(OPEN)
  priority     SupportTicketPriority @default(MEDIUM)
  category     String?
  authorId     String                @db.Uuid
  assignedToId String?               @db.Uuid
  resolvedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?
  replies      SupportTicketReply[]
  assignedTo   User?                 @relation("AssignedTickets", fields: [assignedToId], references: [id])
  author       User                  @relation("AuthoredTickets", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([status])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("support_tickets")
}

model SupportTicketReply {
  id        String        @id @default(uuid()) @db.Uuid
  message   String
  isStaff   Boolean       @default(false)
  ticketId  String        @db.Uuid
  authorId  String        @db.Uuid
  createdAt DateTime      @default(now())
  author    User          @relation("TicketReplies", fields: [authorId], references: [id], onDelete: Cascade)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@map("support_ticket_replies")
}

/// System-level roles controlling access permissions
enum UserRole {
  SUPER_ADMIN
  BD_TEAM
  MENTOR
  STUDENT
}

/// Lifecycle state of a user account
enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
}

/// State of an email invitation token
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

/// Daily attendance outcome for a student
enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  ON_LEAVE
}

/// Lifecycle of a weekly training-plan entry
enum TrainingPlanStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// Category of a leave request
enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  OTHER
}

/// Approval state of a leave request
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Status of a company partnership
enum CompanyStatus {
  ACTIVE
  INACTIVE
}

/// Category used to route and display notifications
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ALERT
  ATTENDANCE
  LEAVE
  TRAINING
}

/// High-level domain grouping for audit log entries
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  OTHER
}

/// Lifecycle state of a support ticket
enum SupportTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

/// Priority level assigned to a support ticket
enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}
