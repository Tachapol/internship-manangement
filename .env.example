# Database Connection
DATABASE_URL="postgresql://devplus_user:devplus_password@localhost:5432/devplus?schema=public"

# Supabase Storage Configuration (for PDF / Leave attachment upload)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="devplus-bucket"

# Resend Email Config
RESEND_API_KEY="re_123456789"
EMAIL_FROM="DevPlus <noreply@devplus.com>"

# WebSockets and API Settings
JWT_SECRET="devplus-jwt-secret-key-change-in-production"
PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
